import base64, json

def b64u(s):
    b = json.dumps(s).encode() if isinstance(s, dict) else s
    return base64.urlsafe_b64encode(b).rstrip(b'=').decode()

# Signatur entfernen -> Server akzeptiert wenn alg-Pruefung fehlt
